# Briefly — environment variables
# Copy this file to ".env" and fill in your Supabase project values.
# (EXPO_PUBLIC_ vars are bundled into the app; the anon key is safe to expose —
#  your data is protected by row-level security, not by hiding this key.)
#
# NOTE: These are the API values (from Settings → API), NOT the Postgres
# connection string. Never put your database password in this file.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
